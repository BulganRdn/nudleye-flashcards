// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

enum Role {
  USER
  ADMIN
}

// NextAuth.js required models
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          Role      @default(USER)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  // Relations
  accounts     Account[]
  sessions     Session[]
  decks        Deck[]
  progress     UserProgress[]
  testSessions TestSession[]

  @@index([email])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// App-specific models
model Deck {
  id          String   @id @default(cuid())
  name        String
  emoji       String   @default("📚")
  description String?
  isPublic    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  // Relations
  authorId String
  author   User   @relation(fields: [authorId], references: [id], onDelete: Cascade)
  cards    Card[]
  progress UserProgress[]

  copiedFromId String?
  copiedFrom   Deck?   @relation("DeckCopies", fields: [copiedFromId], references: [id], onDelete: SetNull)
  copies       Deck[]  @relation("DeckCopies")

  @@index([authorId])
  @@index([isPublic])
  @@index([createdAt])
  @@index([copiedFromId])
}

model Card {
  id        String   @id @default(cuid())
  front     String   // Prompt side
  back      String   // Answer side
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  // Relations
  deckId String
  deck   Deck   @relation(fields: [deckId], references: [id], onDelete: Cascade)
  
  // SRS fields
  easeFactor Float   @default(2.5)
  interval   Int     @default(1)
  repetition Int     @default(0)
  dueDate    DateTime @default(now())

  @@index([deckId])
  @@index([dueDate])
}

model UserProgress {
  id         String   @id @default(cuid())
  userId     String
  deckId     String
  mastered   Int      @default(0)
  total      Int      @default(0)
  streak     Int      @default(0)
  lastStudy  DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  deck Deck @relation(fields: [deckId], references: [id], onDelete: Cascade)
  
  @@unique([userId, deckId])
  @@index([userId])
  @@index([deckId])
}

model TestSession {
  id          String   @id @default(cuid())
  userId      String
  deckId      String?
  sessionType String   @default("practice") // "practice", "test", "daily"
  totalCards  Int      @default(0)
  completed   Int      @default(0)
  correct     Int      @default(0)
  incorrect   Int      @default(0)
  score       Float    @default(0)
  startedAt   DateTime @default(now())
  completedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([deckId])
  @@index([sessionType])
  @@index([completedAt])
}
